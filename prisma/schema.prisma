generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MEMBER
}

enum Platform {
  INSTAGRAM
  TIKTOK
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum OutboxStatus {
  PENDING
  ENQUEUED
  FAILED
}

enum AuthAuditEvent {
  GOOGLE_LINKED
  GOOGLE_UNLINKED
}

enum SocialConnectionStatus {
  ACTIVE
  INVALID
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  credits   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users             User[]
  socialConnections SocialConnection[]
  scheduledPosts    ScheduledPost[]
  assets            Asset[]
  invites           WorkspaceInvite[]

  @@index([slug])
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  /// Null when user signed up with Google only
  passwordHash          String?
  /// Google OAuth subject (sub); unique when set
  googleId              String?   @unique
  name                  String
  role                  Role      @default(MEMBER)
  workspaceId           String
  refreshToken          String?
  refreshTokenExpiresAt DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitesAccepted WorkspaceInvite[] @relation("InviteAcceptedBy")
  authAuditLogs   AuthAuditLog[]

  @@index([email])
  @@index([workspaceId])
  @@index([refreshToken])
}

model Asset {
  id          String   @id @default(cuid())
  workspaceId String
  jobId       String   @unique
  type        String
  url         String
  r2Key       String
  contentType String
  caption     String
  hashtags    String[]
  createdAt   DateTime @default(now())

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  scheduledPosts ScheduledPost[]

  @@index([workspaceId])
  @@index([jobId])
}

model SocialConnection {
  id           String    @id @default(cuid())
  workspaceId  String
  platform     Platform
  accountId    String
  accountName  String
  // AES-256-GCM encrypted: iv:authTag:ciphertext (base64)
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  status       SocialConnectionStatus @default(ACTIVE)
  invalidAt    DateTime?
  lastCheckedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform, accountId])
  @@index([workspaceId, platform])
}

model ScheduledPost {
  id           String     @id @default(cuid())
  workspaceId  String
  assetId      String
  platform     Platform
  caption      String
  hashtags     String[]
  scheduledAt  DateTime
  status       PostStatus @default(DRAFT)
  publishJobId String?
  retryCount   Int        @default(0)
  errorMessage String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  asset     Asset     @relation(fields: [assetId], references: [id])

  @@index([workspaceId])
  @@index([scheduledAt, status])
  @@index([publishJobId])
}

model OutboxJob {
  id          String      @id @default(cuid())
  queue       String
  name        String
  dedupeKey   String?     @unique
  payload     Json
  runAt       DateTime    @default(now())
  status      OutboxStatus @default(PENDING)
  attempts    Int         @default(0)
  lastError   String?
  enqueuedAt  DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([status, runAt])
}

model PaymentCallbackReplay {
  id            String   @id @default(cuid())
  replayKey     String   @unique
  source        String
  conversationId String?
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  @@index([expiresAt])
}

model PaymentTransaction {
  id             String   @id @default(cuid())
  conversationId String   @unique
  workspaceId    String
  creditAmount   Int
  amount         Decimal  @db.Decimal(10, 2)
  status         String
  provider       String   @default("iyzico")
  raw            Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([workspaceId, createdAt])
}

model WorkspaceInvite {
  id            String   @id @default(cuid())
  workspaceId   String
  email         String
  role          Role     @default(MEMBER)
  tokenHash     String   @unique
  invitedById   String
  acceptedById  String?
  expiresAt     DateTime
  consumedAt    DateTime?
  createdAt     DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  acceptedBy User?    @relation("InviteAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@index([workspaceId, email])
  @@index([expiresAt, consumedAt])
}

model AuthAuditLog {
  id              String         @id @default(cuid())
  eventType       AuthAuditEvent
  userId          String?
  email           String
  provider        String
  providerSubject String?
  metadata        Json?
  createdAt       DateTime       @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([email, createdAt])
}
