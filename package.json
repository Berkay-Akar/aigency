{
  "name": "socialcraft-ai",
  "version": "0.1.0",
  "description": "Production-grade AI SaaS for social media content generation and scheduling",
  "main": "dist/server.js",
  "scripts": {
    "predev": "docker compose up -d",
    "dev": "tsx watch src/server.ts",
    "dev:skip-infra": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f redis"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1011.0",
    "@aws-sdk/s3-request-presigner": "^3.1011.0",
    "@fal-ai/client": "^1.9.5",
    "@fastify/cors": "^10.1.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@prisma/client": "^6.19.2",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.2",
    "ioredis": "^5.10.0",
    "openai": "^6.34.0",
    "prisma": "^6.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "pino-pretty": "^13.1.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
