# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/socialcraft

# Redis (BullMQ — must be reachable when the API runs; otherwise ECONNREFUSED on :6379)
# Docker is optional: use `npm run docker:up` for local Redis, or install Redis natively
# (e.g. `brew install redis && redis-server`), or point REDIS_URL to a hosted Redis.
REDIS_URL=redis://localhost:6379

# In development the API process also starts BullMQ workers (fal jobs, publish, outbox).
# Production: omit or set false and run `npm run start:worker` (or a second container).
# START_IN_PROCESS_WORKERS=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Encryption (for OAuth tokens) - 32-byte hex string
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# fal.ai
FAL_API_KEY=your-fal-api-key

# OpenAI (optional GPT prompt enhancement — /ai/enhance-prompt & enhancePrompt on generate)
OPENAI_API_KEY=

# Anthropic (legacy / optional)
ANTHROPIC_API_KEY=

# Storage: cloudinary (default) or r2 — R2 kodu src/services/storage/storage.service.ts içinde yorumda
STORAGE_PROVIDER=cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Cloudflare R2 (STORAGE_PROVIDER=r2 + yorumdaki R2 bloğunu açınca gerekli)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=socialcraft-assets
# R2_PUBLIC_URL=https://your-r2-public-url.com

# iyzico
IYZICO_API_KEY=your-iyzico-api-key
IYZICO_SECRET_KEY=your-iyzico-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
IYZICO_WEBHOOK_HMAC_SECRET=your-iyzico-webhook-hmac-secret
# Optional fallback for dev environments
IYZICO_WEBHOOK_SHARED_SECRET=

# OAuth - Instagram
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/social/callback/instagram

# OAuth - TikTok
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=http://localhost:3000/social/callback/tiktok

# OAuth - Google (optional; leave unset or empty until credentials exist)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

# Resend (invite emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# Rate limit
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW_MS=60000

# App
APP_URL=http://localhost:3000

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
